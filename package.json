{
  "name": "comunidad-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd src/backend && node server.js",
    "dev:frontend": "cd src/frontend && npm run dev",
    "install:all": "npm install && cd src/backend && npm install && cd ../frontend && npm install",
    "db:migrate": "cd src/backend && node -e \"require('dotenv').config();const{pool}=require('./db');const fs=require('fs');const files=['001_initial.sql','002_dashboard.sql','003_expenses.sql','004_comunicacion.sql','005_expense_split.sql','006_soft_delete.sql','007_invites.sql','008_late_fees.sql','009_audit_logs.sql','010_payment_transactions.sql','011_amenities.sql','012_user_type_polls.sql','013_hierarchy.sql','014_hierarchy_fields.sql','015_master_tickets.sql','016_master_ticket_status.sql','017_hierarchy_crud_fields.sql','018_admin_complexes.sql','019_super_admin.sql','020_complex_soft_delete.sql','021_payment_reconciliation_indexes.sql'];files.reduce((p,f)=>p.then(()=>pool.query(fs.readFileSync('./migrations/'+f,'utf8')).then(()=>console.log('Migracion:',f))),Promise.resolve()).then(()=>{console.log('Migraciones OK');pool.end()}).catch(e=>{console.error(e);pool.end();process.exit(1)})\"",
    "db:seed": "cd src/backend && node seed.js",
    "db:setup": "npm run db:migrate && npm run db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
